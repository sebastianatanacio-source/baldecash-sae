# ============================================
# BaldeCash SAE — Variables de entorno
# ============================================
# Copia este archivo a .env.local y rellena los valores.
# En Vercel, configura las mismas variables en Project Settings → Environment Variables.

# Secreto de sesión (32+ caracteres aleatorios). En producción, generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=cambiar_por_un_secreto_largo_de_almenos_32_caracteres_aleatorios

# Contraseñas iniciales (solo se leen al primer arranque; luego se gestionan en /admin)
# En producción, cambiar de inmediato.
ADMIN_PASSWORD=admin2026
JEFA_PASSWORD=jefa2026
FERNANDA_PASSWORD=ff2026
STEFANIA_PASSWORD=sm2026
JULIO_PASSWORD=jl2026

# Vercel Blob — token de lectura/escritura para persistir el snapshot.
# En desarrollo local, si está vacío se usa el archivo data/snapshot.json
BLOB_READ_WRITE_TOKEN=
